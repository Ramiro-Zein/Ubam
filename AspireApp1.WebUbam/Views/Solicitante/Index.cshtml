@model IEnumerable<AspireApp1.WebUbam.Models.Solicitante>

@{
ViewData["Title"] = "Solicitantes";
}

<div class="d-flex justify-content-between align-items-center w-100 my-4">
    <h3>Solicitantes</h3>
</div>

@if (ViewBag.Error != null)
{
<div class="alert alert-danger">
    @ViewBag.Error
</div>
}
else if (!Model.Any())
{
<p>No se encontraron solicitantes.</p>
}
else
{
<table class="table table-striped table-bordered">
    <thead class="table-dark">
    <tr>
        <th>Nombre del Solicitante</th>
        <th>Fecha de Nacimiento</th>
        <th>Número de Referencia del Pago</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var solicitante in Model)
    {
    <tr>
        <td>@solicitante.Nombre_Solicitante</td>
        <td>@solicitante.Fecha_Nacimiento_Solicitante.ToString("dd/MM/yyyy")</td>
        <td>
            @if (solicitante.Pagos != null && solicitante.Pagos.Any())
            {
            @solicitante.Pagos.First().Referencia_Pago
            }
            else
            {
            <span>N/A</span>
            }
        </td>
    </tr>
    }
    </tbody>
</table>
}
