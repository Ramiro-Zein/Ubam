@{
    ViewData["Title"] = "Home Page";
}

<head>
    <style>
        .welcome-section {
            background: linear-gradient(135deg, #6a11cb 0%, #0040ac 100%);
            color: white;
            padding: 50px 20px;
            text-align: center;
            position: relative;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .welcome-section h1 {
            font-size: 3rem;
            margin-bottom: 20px;
            animation: fadeInDown 1s ease-out;
        }

        .logout-button {
            position: absolute;
            top: 20px;
            right: 20px;
        }

        .logout-button .btn {
            transition: background-color 0.3s, transform 0.3s;
        }

        .logout-button .btn:hover {
            background-color: #ff4b5c;
            transform: scale(1.05);
        }

        .logout-button {
            position: static;
            margin-top: 20px;
        }
    </style>
</head>
<body class="bg-light">

<div class="container my-5">
    <div class="welcome-section position-relative">
        <h1>¡Bienvenido!</h1>
        <p>Estamos encantados de tenerte con nosotros. Disfruta de tu experiencia.</p>
        <form class="logout-button" asp-controller="Login" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-secondary">
                <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
            </button>
        </form>
    </div>
</div>
</body>