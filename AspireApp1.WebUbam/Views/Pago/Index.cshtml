@model IEnumerable<AspireApp1.WebUbam.Models.Pago>

@{
    ViewData["Title"] = "Pagos";
}

<div class="d-flex justify-content-between align-items-center w-100 my-4">
    <h3>Pagos</h3>
    <div class="nav-item">
        <a class="nav-link btn btn-dark text-white" href="/agregarPago">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus me-2" viewBox="0 0 16 16">
                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
            </svg> Agregar Pago
        </a>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}
else if (!Model.Any())
{
    <p>No se encontraron pagos.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
        <tr>
            <th>Concepto</th>
            <th>Monto</th>
            <th>Cuenta</th>
            <th>Sucursal</th>
            <th>Referencia</th>
            <th>Banco</th>
            <th>Fecha Límite</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var pago in Model)
        {
            <tr>
                <td>@pago.Concepto_Pago</td>
                <td>@pago.Monto_Pago</td>
                <td>@pago.Cuenta_Pago</td>
                <td>@pago.Sucursal_Pago</td>
                <td>@pago.Referencia_Pago</td>
                <td>@pago.Banco_Pago</td>
                <td>@pago.Fecha_Limite_Pago.ToString("dd/MM/yyyy")</td>
            </tr>
        }
        </tbody>
    </table>
}
