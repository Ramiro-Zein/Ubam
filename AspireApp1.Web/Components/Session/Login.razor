@page "/login"

@layout Layout.EmptyLayout

<div class="page">
    <div class="container">
        <div class="login-box">
            <h2>Iniciar Sesión</h2>
            <form>
                <div class="input-box">
                    <input type="text" @bind="username" required placeholder="Ingrese su usuario">
                    <label>Usuario</label>
                </div>
                <div class="input-box">
                    <input type="password" @bind="password" required placeholder="Ingrese su contraseña">
                    <label>Contraseña</label>
                </div>
                <button type="button" class="login-btn" @onclick="Entrar">Entrar</button>
                <p class="register-text">¿No tienes una cuenta? <a href="#">Regístrate</a></p>
            </form>
        </div>
    </div>
</div>

@code {
    private string username;
    private string password;

    [Inject]
    private NavigationManager Navigation { get; set; }

    private void Entrar()
    {
        Navigation.NavigateTo("/welcome");
    }
}