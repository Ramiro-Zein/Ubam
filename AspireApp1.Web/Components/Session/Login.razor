@page "/login"
@layout Layout.EmptyLayout
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="page">
    <div class="container">
        <div class="login-box">
            <h2>Iniciar Sesión</h2>
            @if (!string.IsNullOrEmpty(mensajeAlerta))
            {
                <div class="alert alert-info">@mensajeAlerta</div>
            }
            <form>
                <div class="input-box">
                    <input type="text" @bind="_username" required placeholder="">
                    <label>Usuario</label>
                </div>
                <div class="input-box">
                    <input type="password" @bind="_password" required placeholder="">
                    <label>Contraseña</label>
                </div>
                <button type="button" class="login-btn" @onclick="Entrar">Entrar</button>
                <p class="register-text">¿No tienes una cuenta? <a href="#">Regístrate</a></p>
            </form>
        </div>
    </div>
</div>

@code {
    private string? _username;
    private string? _password;
    private string mensajeAlerta;

    private async Task Entrar()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            mensajeAlerta = "Por favor, ingresa usuario y contraseña.";
            return;
        }

        var loginRequest = new { Username = _username, Password = _password };
        var response = await Http.PostAsJsonAsync("http://localhost:5561/api/auth/login", loginRequest);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            mensajeAlerta = $"Bienvenido, {_username}!";
            Navigation.NavigateTo("/auth/home");
        }
        else
        {
            mensajeAlerta = "Usuario o contraseña incorrectos.";
        }
    }

    private class LoginResponse
    {
        public string Message { get; set; }
        public Guid UserId { get; set; }
    }

}