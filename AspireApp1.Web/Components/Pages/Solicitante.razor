@page "/auth/solicitante"
@inject HttpClient Http

<PageTitle>Solicitante</PageTitle>

<h3>Solicitante</h3>

@if (_solicitantes == null)
{
    <p>
        <em>Loading...</em>
    </p>
}
else if (_solicitantes.Count == 0)
{
    <p>No users found.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Birth Date</th>
            <th>Pagos</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var solicitante in _solicitantes)
        {
            <tr>
                <td>@solicitante.Nombre_Solicitante</td>
                <td>@solicitante.Fecha_Nacimiento_Solicitante.ToShortDateString()</td>
                <td>
                    @if (solicitante.Pagos.Any())
                    {
                        <ul>
                            @foreach (var pago in solicitante.Pagos)
                            {
                                <li>
                                    <strong>Monto:</strong> @pago.Monto_Pago, 
                                    <strong>Cuenta:</strong> @pago.Cuenta_Pago, 
                                    <strong>Fecha Límite:</strong> @pago.Fecha_Limite_Pago.ToShortDateString()
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <em>No hay pagos disponibles</em>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<Models.Solicitante>? _solicitantes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _solicitantes = await Http.GetFromJsonAsync<List<Models.Solicitante>>("http://localhost:5561/api/solicitantes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al obtener los solicitantes: {ex.Message}");
        } 
    }
}
